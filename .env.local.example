# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key_here

# Business ID (UUID from the businesses table after running seed.sql)
NEXT_PUBLIC_BUSINESS_ID=your-business-uuid

# Resend (email notifications for catering inquiries)
RESEND_API_KEY=re_your_api_key
CATERING_INQUIRY_EMAIL=owner@example.com
